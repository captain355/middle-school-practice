generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 学校表
model School {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  code         String?  @unique @db.VarChar(20)    // 学校代码，学生加入用
  address      String?
  contactName  String?  @map("contact_name") @db.VarChar(50)
  contactPhone String?  @map("contact_phone") @db.VarChar(20)
  maxStudents  Int      @default(500) @map("max_students")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  classes Class[] @relation("SchoolClasses")
  users    User[]   @relation("SchoolUsers")

  @@map("schools")
}

// 班级表
model Class {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String   @db.VarChar(50)
  grade     Int                                          // 7/8/9
  teacherId String?  @map("teacher_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school   School  @relation("SchoolClasses", fields: [schoolId], references: [id], onDelete: Cascade)
  teacher  User?    @relation("ClassTeacher", fields: [teacherId], references: [id])
  students User[]   @relation("ClassStudents")

  @@unique([schoolId, name])
  @@map("classes")
}

// 用户表（学生/教师/管理员）
model User {
  id            String    @id @default(uuid())
  username      String    @unique @db.VarChar(50)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  displayName   String    @map("display_name") @db.VarChar(50)
  role          String    @default("student") @db.VarChar(20)  // admin | teacher | student
  avatar        String?
  schoolId      String?   @map("school_id")
  classId       String?   @map("class_id")
  grade         Int?
  isDisabled    Boolean   @default(false) @map("is_disabled")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school           School?            @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: SetNull)
  teacherClasses    Class[]            @relation("ClassTeacher")
  studentClass      Class?             @relation("ClassStudents", fields: [classId], references: [id])
  practiceRecords   PracticeRecord[]
  wrongQuestions    WrongQuestion[]
  progress          StudentProgress[]
  checkinStreak     CheckinStreak?

  @@map("users")
}

// 学科表
model Subject {
  id          String   @id @db.VarChar(20)  // math, chinese, english...
  name        String   @db.VarChar(20)
  emoji       String?  @db.VarChar(10)
  color       String?  @db.VarChar(10)
  description String?
  tags        String[]
  gradeRange  Int[]    @map("grade_range")  // [7,8,9]
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  textbooks Textbook[] @relation("SubjectTextbooks")

  @@map("subjects")
}

// 教材版本表
model Textbook {
  id          String   @id @default(uuid())
  subjectId   String   @map("subject_id") @db.VarChar(20)
  code        String   @db.VarChar(30)  // renjiao, pep...
  name        String   @db.VarChar(50)  // 人教版
  publisher   String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  subject  Subject  @relation("SubjectTextbooks", fields: [subjectId], references: [id], onDelete: Cascade)
  chapters Chapter[]

  @@unique([subjectId, code])
  @@map("textbooks")
}

// 章节表
model Chapter {
  id              String   @id @default(uuid())
  textbookId      String   @map("textbook_id")
  grade           Int
  sortOrder       Int      @map("sort_order")
  name            String   @db.VarChar(100)
  knowledgePoints Int      @default(0) @map("knowledge_points")
  exercises       Int      @default(0)
  chapterKey      String   @unique @map("chapter_key") @db.VarChar(30)  // 格式: "7-0", "8-2"
  createdAt       DateTime @default(now()) @map("created_at")

  textbook Textbook  @relation(fields: [textbookId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("chapters")
}

// 题目表
model Question {
  id                String   @id @default(uuid())
  chapterId         String   @map("chapter_id")
  questionKey       String   @unique @map("question_key") @db.VarChar(30)  // q1, q2000...
  type              String   @db.VarChar(20)  // choice | fill | truefalse | matching | shortanswer
  questionText      String   @map("question_text") @db.Text
  answer            String   @db.Text
  explanation       String?  @db.Text
  difficulty        Int      @default(1)  // 1/2/3
  options           Json?    // choice/truefalse: ["A. xxx", ...]
  pairs             Json?    // matching: [{left, right}, ...]
  acceptableAnswers Json?    @map("acceptable_answers")  // shortanswer: ["关键词1", ...]
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  chapter        Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  wrongQuestions WrongQuestion[] @relation("QuestionWrongs")

  @@map("questions")
}

// 练习记录表
model PracticeRecord {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  chapterId  String?  @map("chapter_id")
  subjectId  String?  @map("subject_id") @db.VarChar(20)
  textbookId String?  @map("textbook_id")
  score      Int
  correct    Int
  total      Int
  duration   Int?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("practice_records")
}

// 错题本表
model WrongQuestion {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  questionId   String    @map("question_id")
  userAnswer   String    @map("user_answer") @db.Text
  wrongCount   Int       @default(1) @map("wrong_count")
  lastWrongAt  DateTime  @default(now()) @map("last_wrong_at")
  isMastered   Boolean   @default(false) @map("is_mastered")
  masteredAt   DateTime? @map("mastered_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation("QuestionWrongs", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("wrong_questions")
}

// 学生进度表
model StudentProgress {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  chapterId        String    @map("chapter_id")
  bestScore        Int       @default(0) @map("best_score")
  totalQuestions   Int       @default(0) @map("total_questions")
  correctQuestions Int       @default(0) @map("correct_questions")
  attempts         Int       @default(0)
  lastPracticeAt   DateTime? @map("last_practice_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@map("student_progress")
}

// 打卡表
model CheckinStreak {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  streakCount Int      @default(0) @map("streak_count")
  lastDate    DateTime @map("last_date") @db.Date
  totalDays   Int      @default(0) @map("total_days")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("checkin_streaks")
}
