{
  "name": "middle-school-practice",
  "private": true,
  "version": "1.0.0",
  "description": "初中各学科知识体系专项练习库",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev": "npm run dev:server & npm run dev:client",
    "build:client": "npm run build --workspace=packages/client",
    "build:server": "npm run build --workspace=packages/server",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "build:shared": "npm run build --workspace=packages/shared",
    "lint": "oxlint",
    "db:migrate": "npm run db:migrate --workspace=packages/server",
    "db:seed": "npm run db:seed --workspace=packages/server",
    "db:import-questions": "npm run import-questions --workspace=packages/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
